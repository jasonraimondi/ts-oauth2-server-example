{
  "name": "jmondi-oauth2-example-server",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "lint": "oxlint --type-aware src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "@jmondi/date-duration": "^0.1.1",
    "@jmondi/oauth2-server": "5.0.0-rc.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.19",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  }
}
