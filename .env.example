# Postgres connection string. The default below already matches the bundled
# docker-compose.yml — change it only to point at a different database.
DATABASE_URL="postgresql://oauth:secret@localhost:8888/oauth_example"

# OIDC issuer; also the base URL for the discovery + JWKS endpoints. Defaults to
# http://localhost:3000 when unset.
OIDC_ISSUER="http://localhost:3000"

# RSA private key (PEM) used to sign OIDC tokens; the public half is published at
# /.well-known/jwks.json. Newlines may be escaped as \n on a single line. If unset,
# an ephemeral key is generated at boot (tokens won't survive a restart). Generate one:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# OIDC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Symmetric secret (HS256) for the browser session cookie ("jid"). Deliberately
# separate from the OIDC signing key — it lives in a different trust domain. If
# unset, an insecure hardcoded dev default is used (with a warning). Set this in
# production to a long random string.
# SESSION_SECRET="change-me-to-a-long-random-string"
