# The BFF (this SvelteKit server) is a confidential OAuth client. These vars are
# SERVER-ONLY (read via $env/dynamic/private) and never exposed to the browser.
# Dev defaults in src/lib/server/config.ts match the seeded "BFF Web Client", so
# the demo runs without this file — copy to .env to override.

OIDC_ISSUER=http://localhost:3000
OAUTH_CLIENT_ID=b1ff0000-0000-4000-8000-000000000001
# Plaintext secret; the authorization server stores only its bcrypt hash.
OAUTH_CLIENT_SECRET=bff-dev-secret-change-me
OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback
